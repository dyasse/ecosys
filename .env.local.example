# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# ── Brevo ──────────────────────────────────────────────────
# Get from: brevo.com → Settings → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Get from: brevo.com → Contacts → Lists → click your list → ID is in the URL
BREVO_LIST_ID=42

# ── Supabase ───────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXX

# Safe for browser (anon key, read-only by default)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXX

# ── Site URL ───────────────────────────────────────────────
# Local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production (change in Vercel dashboard):
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Google Analytics 4 (optional) ─────────────────────────
# Get from: analytics.google.com → your property → Data Streams → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
